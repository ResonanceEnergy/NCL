{
  "$id": "https://resonance.energy/schemas/ncl.iphone.v1/health.resting_hr_trend.json",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Resting Heart Rate Trend",
  "description": "Resting heart rate trend and summary statistics.",
  "allOf": [
    { "$ref": "./envelope.json#" },
    {
      "properties": {
        "event_type": { "const": "ncl.health.resting_hr_trend" },
        "payload": {
          "type": "object",
          "required": ["window_start","window_end","median_resting_hr"],
          "properties": {
            "window_start": { "type": "string", "format": "date-time" },
            "window_end": { "type": "string", "format": "date-time" },
            "median_resting_hr": { "type": "number" },
            "trend_delta_bpm": { "type": "number" }
          },
          "additionalProperties": false
        }
      }
    }
  ]
}