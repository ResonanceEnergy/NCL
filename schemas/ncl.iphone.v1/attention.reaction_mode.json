{
  "$id": "https://resonance.energy/schemas/ncl.iphone.v1/attention.reaction_mode.json",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Reaction Mode Score",
  "description": "Derived score indicating reactionary attention (0.0 - 1.0).",
  "allOf": [
    { "$ref": "./envelope.json#" },
    {
      "properties": {
        "event_type": { "const": "ncl.attention.reaction_mode" },
        "payload": {
          "type": "object",
          "required": ["timestamp","score"],
          "properties": {
            "timestamp": { "type": "string", "format": "date-time" },
            "score": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
            "notes": { "type": "string" }
          },
          "additionalProperties": false
        }
      }
    }
  ]
}