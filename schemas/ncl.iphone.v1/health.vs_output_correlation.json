{
  "$id": "https://resonance.energy/schemas/ncl.iphone.v1/health.vs_output_correlation.json",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Health vs Output Correlation",
  "description": "Correlation metadata between health signals and measured output/productivity metrics.",
  "allOf": [
    { "$ref": "./envelope.json#" },
    {
      "properties": {
        "event_type": { "const": "ncl.health.vs_output_correlation" },
        "payload": {
          "type": "object",
          "required": ["window_start","window_end","correlation_score"],
          "properties": {
            "window_start": { "type": "string", "format": "date" },
            "window_end": { "type": "string", "format": "date" },
            "correlation_score": { "type": "number", "minimum": -1.0, "maximum": 1.0 },
            "notes": { "type": "string" }
          },
          "additionalProperties": false
        }
      }
    }
  ]
}