{
  "$id": "https://resonance.energy/schemas/ncl.iphone.v1/health.vitals_outlier_count.json",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Vitals Outlier Count",
  "description": "Count of vitals outliers detected in a window (single readiness flag source).",
  "allOf": [
    { "$ref": "./envelope.json#" },
    {
      "properties": {
        "event_type": { "const": "ncl.health.vitals_outlier_count" },
        "payload": {
          "type": "object",
          "required": ["window_start","window_end","outlier_count"],
          "properties": {
            "window_start": { "type": "string", "format": "date-time" },
            "window_end": { "type": "string", "format": "date-time" },
            "outlier_count": { "type": "integer", "minimum": 0 }
          },
          "additionalProperties": false
        }
      }
    }
  ]
}