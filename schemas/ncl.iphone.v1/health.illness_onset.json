{
  "$id": "https://resonance.energy/schemas/ncl.iphone.v1/health.illness_onset.json",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Illness Onset Detector",
  "description": "Event indicating potential illness onset from multimodal signals.",
  "allOf": [
    { "$ref": "./envelope.json#" },
    {
      "properties": {
        "event_type": { "const": "ncl.health.illness_onset" },
        "payload": {
          "type": "object",
          "required": ["detected_at","confidence"],
          "properties": {
            "detected_at": { "type": "string", "format": "date-time" },
            "confidence": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
            "indicators": { "type": "array", "items": { "type": "string" } }
          },
          "additionalProperties": false
        }
      }
    }
  ]
}