<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- NCL Intelligence Council Sweep — runs every 6 hours -->
    <!-- Install: cp config/com.resonanceenergy.ncl-councils.plist ~/Library/LaunchAgents/ -->
    <!-- Load:    launchctl bootstrap gui/$(id -u) ~/Library/LaunchAgents/com.resonanceenergy.ncl-councils.plist -->
    <!-- Unload:  launchctl bootout gui/$(id -u)/com.resonanceenergy.ncl-councils -->
    <!-- Status:  launchctl list | grep ncl-councils -->

    <key>Label</key>
    <string>com.resonanceenergy.ncl-councils</string>

    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>-c</string>
        <string>cd ~/dev/NCL &amp;&amp; ./run-councils.sh both --session-id=sweep-$(date +%Y%m%d-%H%M) 2>&1 | tee -a ~/dev/NCL/logs/council-sweep.log</string>
    </array>

    <key>StartInterval</key>
    <integer>21600</integer><!-- 6 hours = 21600 seconds -->

    <key>WorkingDirectory</key>
    <string>__HOME__/dev/NCL</string>

    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:__HOME__/.pyenv/shims</string>
        <key>HOME</key>
        <string>__HOME__</string>
    </dict>

    <key>StandardOutPath</key>
    <string>__HOME__/dev/NCL/logs/council-sweep-stdout.log</string>

    <key>StandardErrorPath</key>
    <string>__HOME__/dev/NCL/logs/council-sweep-stderr.log</string>

    <key>RunAtLoad</key>
    <false/>

    <key>Nice</key>
    <integer>10</integer><!-- Low priority — don't interfere with active work -->
</dict>
</plist>
