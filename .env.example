# NCL Brain Service — API Keys
# Copy to .env and fill in your keys: cp .env.example .env

# ── Claude (Council Chair + War Room Analysis)
ANTHROPIC_API_KEY=sk-ant-...

# ── Strike Point Pipeline
STRIKE_AUTH_TOKEN=your-auth-token-here

# ── Pushover (iPhone Push Notifications)
# Get from: https://pushover.net
PUSHOVER_APP_TOKEN=
PUSHOVER_USER_KEY=

# ── xAI Grok (Council Member + X Intelligence)
# Get from: https://console.x.ai
XAI_API_KEY=

# ── Google (Gemini + YouTube)
GOOGLE_API_KEY=
YOUTUBE_API_KEY=

# ── Perplexity (Research)
PERPLEXITY_API_KEY=

# ── OpenAI GPT (Optional Council Member)
OPENAI_API_KEY=

# ── X/Twitter (Optional — twscrape used as fallback)
X_BEARER_TOKEN=

# ── Local Models
OLLAMA_HOST=localhost:11434

# ── Paperclip Integration
PAPERCLIP_URL=http://localhost:3100
PAPERCLIP_COMPANY_ID=
PAPERCLIP_AGENT_KEY=

# ── Service URLs (override only if non-standard)
# NCL_BRAIN_URL=http://localhost:8800
# NCC_SERVER_URL=http://localhost:8765
# RELAY_URL=https://localhost:8443

# ── Execution Mode ("auto" or "manual")
NCL_EXECUTION_MODE=auto
