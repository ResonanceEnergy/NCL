# NCL Brain — env var template. Copy to .env and replace <KEYCHAIN> placeholders.
# Secrets are normally pulled from macOS Keychain via runtime.api.config.keychain_get;
# set them in this file only when Keychain is unavailable (Docker/Linux/CI).
#
# Every variable read by runtime/api/config.py is represented below. Boolean
# values are lowercase "true"/"false"; numeric values are unquoted integers.
# The NCL_ prefix is honoured for Docker overrides (e.g. NCL_PORT=8801).

# ── Required ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=<KEYCHAIN>                  # Claude API key — Council Chair + memory enrichment
STRIKE_AUTH_TOKEN=<KEYCHAIN>                  # Strike Point auth token — must match iOS Shortcuts config

# ── Recommended (degraded if missing) ────────────────────────────────────────
XAI_API_KEY=<KEYCHAIN>                        # xAI Grok — Council Strategist + X intelligence
GOOGLE_API_KEY=<KEYCHAIN>                     # Google Gemini — Council Analyst
GEMINI_API_KEY=<KEYCHAIN>                     # Alias for GOOGLE_API_KEY (keychain: ncl-gemini)
OPENAI_API_KEY=<KEYCHAIN>                     # OpenAI GPT — Council Creative + Whisper fallback
PERPLEXITY_API_KEY=<KEYCHAIN>                 # Perplexity — Council Researcher / fact-checking
COPILOT_API_KEY=<KEYCHAIN>                    # GitHub Copilot — engineering council (falls back to OPENAI_API_KEY)

# ── Social media APIs ────────────────────────────────────────────────────────
X_BEARER_TOKEN=<KEYCHAIN>                     # X/Twitter API v2 — bearer for tweet scanning
YOUTUBE_API_KEY=<KEYCHAIN>                    # YouTube Data API — video search for YTC
REDDIT_CLIENT_ID=<KEYCHAIN>                   # Reddit — OAuth client id
REDDIT_CLIENT_SECRET=<KEYCHAIN>               # Reddit — OAuth client secret

# ── News APIs ────────────────────────────────────────────────────────────────
GNEWS_API_KEY=<KEYCHAIN>                      # GNews — news intelligence (one news key is enough)
NEWSAPI_KEY=<KEYCHAIN>                        # NewsAPI — news intelligence

# ── Market intelligence ──────────────────────────────────────────────────────
UNUSUAL_WHALES_API_KEY=<KEYCHAIN>             # Unusual Whales — options flow / dark pool
UNUSUAL_WHALES_TOKEN=<KEYCHAIN>               # Alias for UNUSUAL_WHALES_API_KEY
SNAPTRADE_CLIENT_ID=<KEYCHAIN>                # SnapTrade — Wealthsimple brokerage data
SNAPTRADE_CONSUMER_KEY=<KEYCHAIN>             # SnapTrade — consumer key (pair with client id)

# ── Notifications ────────────────────────────────────────────────────────────
NTFY_TOPIC=<KEYCHAIN>                         # ntfy.sh topic — push notifications to iPhone
NTFY_SERVER=https://ntfy.sh                   # ntfy server URL (override for self-hosted)
PUSHOVER_APP_TOKEN=<KEYCHAIN>                 # Pushover — app token (fallback push)
PUSHOVER_USER_KEY=<KEYCHAIN>                  # Pushover — user key (pair with app token)
DISCORD_BOT_TOKEN=<KEYCHAIN>                  # Discord bot — channel push notifications

# ── Paperclip (retired — see runtime/cost_tracker.py) ────────────────────────
PAPERCLIP_API_KEY=<KEYCHAIN>                  # Legacy; Paperclip backend was never deployed
PAPERCLIP_AGENT_KEY=<KEYCHAIN>                # Legacy alias
PAPERCLIP_COMPANY_ID=<KEYCHAIN>               # Legacy company id

# ── Service ──────────────────────────────────────────────────────────────────
SERVICE_NAME=ncl-brain                        # Service identifier
SERVICE_VERSION=1.0.0                         # Reported via /system/health
HOST=0.0.0.0                                  # Bind address
PORT=8800                                     # FastAPI port
DEBUG=false                                   # Verbose logging + debug routes

# ── Storage ──────────────────────────────────────────────────────────────────
DATA_DIR=~/dev/NCL/data                       # Memory + journal + costs (expanded at startup)
CONFIG_DIR=~/dev/NCL/config                   # YAML config + watchlists

# ── Intelligence cadences (seconds) ──────────────────────────────────────────
INTELLIGENCE_BRIEF_INTERVAL=14400             # 4h between full briefs
INTELLIGENCE_COLLECTION_INTERVAL=1800         # 30m between signal sweeps

# ── Local models ─────────────────────────────────────────────────────────────
OLLAMA_HOST=localhost:11434                   # Local LLM endpoint

# ── Digital Labour integration ───────────────────────────────────────────────
DIGITAL_LABOUR_PATH=~/dev/NCL/digital-labour  # Local digital labour artifacts

# ── Scan intervals (seconds) ─────────────────────────────────────────────────
X_SCAN_INTERVAL=1800                          # X (30m — was 5m, burned $25-36/day)
YOUTUBE_SCAN_INTERVAL=600                     # YouTube (10m)
REDDIT_SCAN_INTERVAL=600                      # Reddit (10m)
PREDICTION_INTERVAL=1800                      # Predictions (30m)
MEMORY_CONSOLIDATION_INTERVAL=3600            # Memory consolidation (1h)

# ── Memory parameters ────────────────────────────────────────────────────────
MEMORY_IMPORTANCE_THRESHOLD=20.0              # Minimum score to keep a unit
MEMORY_DECAY_RATE=0.95                        # Daily SML decay
MEMORY_CONSOLIDATION_BATCH_SIZE=50            # Units per consolidation batch

# ── Council settings ─────────────────────────────────────────────────────────
COUNCIL_TIMEOUT=120                           # Per-member response timeout (seconds)
COUNCIL_MODEL=claude-sonnet-4-20250514        # Chair model id

# ── WAR Room (retired 2026-05-23 — AAC pillar orphaned) ──────────────────────
# AAC_WAR_ROOM_URL removed; pillar no longer used.

# ── Autonomous scheduler ─────────────────────────────────────────────────────
AUTONOMOUS_ENABLED=true                       # Master kill switch for background loops
COUNCIL_TRIGGER_THRESHOLD=75.0                # Auto-spawn council on score >= this
COUNCIL_MIN_SIGNALS=3                         # Minimum converging signals before spawn
STRATEGIC_REVIEW_INTERVAL=14400               # 4h between scheduled reviews
# AAC_SYNC_INTERVAL removed 2026-05-23 — AAC pillar retired.
WORKSPACE_HEALTH_INTERVAL=1800                # 30m between workspace pipeline checks

# ── Execution mode ───────────────────────────────────────────────────────────
NCL_EXECUTION_MODE=auto                       # "auto" or "manual"

# ── Anthropic base URL (rarely overridden) ───────────────────────────────────
ANTHROPIC_BASE_URL=https://api.anthropic.com  # Override for proxy / self-hosted gateway
