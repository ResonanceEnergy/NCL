# ╔══════════════════════════════════════════════════════════════════════════╗
# ║  NCL Brain Service — Environment Configuration                         ║
# ║  Copy this file: cp .env.example .env                                  ║
# ║  Then fill in your API keys below.                                     ║
# ╚══════════════════════════════════════════════════════════════════════════╝

# ── REQUIRED ────────────────────────────────────────────────────────────────
# Without these the brain will refuse to start.

# Claude API — Council Chair, mandate generation, LDE, UNI Research
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# Strike Point auth token — secures the iPhone → NCL pipeline
# Generate one: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
# Copy into iOS Shortcuts AND here (must match)
STRIKE_AUTH_TOKEN=

# ── RECOMMENDED ─────────────────────────────────────────────────────────────
# These unlock major features. Pipeline works without them but degrades.

# xAI Grok — Council Strategist + X Intelligence analysis
# Get from: https://console.x.ai
XAI_API_KEY=

# Ollama — Local model fallback (free, runs on your Mac)
# Install: brew install ollama && ollama serve
# Pull models: ollama pull qwen3:32b && ollama pull deepseek-coder-v2:16b
OLLAMA_HOST=localhost:11434

# ── COUNCIL MEMBERS ─────────────────────────────────────────────────────────
# Each key enables one council member. More keys = richer debates.

# Google Gemini — Council Analyst
# Get from: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=

# OpenAI GPT — Council Creative + Whisper transcription fallback
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Perplexity — Council Researcher (fact-checking, source-backed)
# Get from: https://www.perplexity.ai/settings/api
PERPLEXITY_API_KEY=

# GitHub Copilot / Engineering council member (falls back to OPENAI_API_KEY if not set)
COPILOT_API_KEY=

# ── INTELLIGENCE SCANNING ──────────────────────────────────────────────────
# Powers the Awarebot scanner and YouTube/X Councils.

# YouTube Data API — video search for YouTube Council
# Get from: https://console.cloud.google.com/apis/credentials
YOUTUBE_API_KEY=

# X/Twitter API v2 — tweet scanning for X Council
# Get from: https://developer.twitter.com/en/portal/dashboard
X_BEARER_TOKEN=

# Reddit — subreddit scanning (optional)
# Get from: https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# News Intelligence (GNews or NewsAPI — at least one needed for news collector)
# GNews: https://gnews.io  |  NewsAPI: https://newsapi.org
GNEWS_API_KEY=
NEWSAPI_KEY=

# ── NOTIFICATIONS ──────────────────────────────────────────────────────────
# Push alerts to your iPhone when mandates need approval.

# ntfy.sh — FREE push notifications, no account needed
# Install ntfy app on iPhone → subscribe to this topic → done
NTFY_TOPIC=
NTFY_SERVER=https://ntfy.sh

# Pushover — iPhone push notifications (optional fallback)
# Get from: https://pushover.net
PUSHOVER_APP_TOKEN=
PUSHOVER_USER_KEY=

# ── INTEGRATIONS ──────────────────────────────────────────────────────────

# Discord bot token — for push notifications to Discord channels
# Get from: https://discord.com/developers/applications
DISCORD_BOT_TOKEN=

# ── INTERNAL SERVICES ──────────────────────────────────────────────────────
# Only change these if running non-standard ports.

# Paperclip project management integration
PAPERCLIP_URL=http://localhost:3100
PAPERCLIP_COMPANY_ID=
PAPERCLIP_AGENT_KEY=

# Service URLs (defaults are fine for local Mac)
# NCL_BRAIN_URL=http://localhost:8800
# NCC_SERVER_URL=http://localhost:8765
# RELAY_URL=https://localhost:8443

# Execution mode: "auto" runs full pipeline, "manual" stops at each gate
NCL_EXECUTION_MODE=auto

# ── MARKET INTELLIGENCE ───────────────────────────────────────────────────

# Unusual Whales — options flow, dark pool, congress trades
# Get from: https://unusualwhales.com/api
UNUSUAL_WHALES_API_KEY=

# SnapTrade — brokerage connections + trade data
# Get from: https://snaptrade.com/developers
SNAPTRADE_CLIENT_ID=
SNAPTRADE_CONSUMER_KEY=

# ── DIGITAL LABOUR FLEET ──────────────────────────────────────────────────

# Path to DIGITAL-LABOUR repo on this machine
DIGITAL_LABOUR_PATH=/Users/yourname/dev/DIGITAL-LABOUR
# Mode: "local" (direct Python imports) or "http" (API calls to DL server)
DIGITAL_LABOUR_MODE=local
# DL API URL (only used in http mode)
DIGITAL_LABOUR_API_URL=http://localhost:8001
