    "content_filtering": true,
    "bias_detection": true,
    "fact_checking": false,
    "human_oversight_required": false
  },
  "performance": {
    "max_concurrent_channels": 5,
    "request_timeout_seconds": 30,
    "retry_attempts": 3,
