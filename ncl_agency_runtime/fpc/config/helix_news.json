{
    "tts": {
        "engine": "edge-tts",
        "voice": "en-US-AvaNeural",
        "rate": "+12%",
        "pitch": "+3Hz",
        "output_format": "mp3"
    },
    "avatar": {
        "engine": "grok_imagine",
        "source_image": "ncl_agency_runtime/fpc/helix_news/assets/helix_portrait.png",
