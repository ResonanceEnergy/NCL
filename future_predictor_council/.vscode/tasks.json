{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "quick",
      "type": "shell",
      "command": "python -m src.cli --data data/raw/example.csv --freq D --h 14",
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "ci",
      "type": "shell",
      "command": "python -m ruff check src/ && python -m pytest tests/ -q && python -m src.cli --data data/raw/example.csv --freq D --h 14",
      "group": "test",
      "problemMatcher": []
    },
    {
      "label": "burst-chronos",
      "type": "shell",
      "command": "python -m src.cli --data data/raw/example.csv --freq D --h 14 --foundation on",
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "serve",
      "type": "shell",
      "command": "uvicorn src.serve:app --host 0.0.0.0 --port 8000 --reload",
      "group": "build",
      "isBackground": true,
      "problemMatcher": []
    }
  ]
}
