  "council_separation": {
    "status": "separated",
    "rationale": "Council serves as strategic oversight, not operational control",
    "boundaries": [
      "Council provides strategic direction only",
      "Departments handle all operational execution",
      "Council approval required for major structural changes",
      "Daily operations autonomous within department authority levels"
    ]
  },
  "authority_hierarchy": {
    "AZ_FINAL": {
      "level": 5,
      "description": "Executive Council - Final Authority",
      "approval_required": ["structural_changes", "doctrine_modifications", "crisis_responses"]
    },
    "HIGH": {
      "level": 4,
      "description": "Department Heads - High Authority",
      "approval_required": ["departmental_changes", "resource_allocation", "policy_changes"]
    },
    "STANDARD": {
      "level": 3,
      "description": "Division Leads - Standard Authority",
      "approval_required": ["operational_changes", "process_modifications"]
    },
    "BASIC": {
      "level": 2,
      "description": "Standard Agents - Basic Authority",
      "approval_required": ["routine_operations"]
    }
  },
